# Зависимости
node_modules/

# Данные — никогда не должны попасть в репозиторий:
# реальные устройства, PIN-коды пользователей, бэкапы
data/

# TLS-ключ
*.pem

# Временные тестовые директории (создаются jest/backup тестами)
/tmp/
it-assets-backup-test-*/

# Отчёты покрытия
coverage/

# Логи, временные файлы ОС
npm-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db

# Локальные переопределения окружения
.env
.env.local
